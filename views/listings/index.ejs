<% layout("/layouts/boilerplate") %>

<style>
.search-header {
  margin-top: 20px;
  margin-bottom: 10px;
}

.search-title {
  font-size: 22px;
  font-weight: 600;
  color: #222;
}

.search-sub {
  font-size: 14px;
  color: #717171;
}

.clear-btn {
  display: inline-block;
  margin-top: 8px;
  padding: 6px 12px;
  border-radius: 20px;
  border: 1px solid #ddd;
  text-decoration: none;
  color: #222;
  font-size: 13px;
  transition: 0.2s;
}

.clear-btn:hover {
  background: #f7f7f7;
  border-color: #aaa;
}

.listing-card {
  border: none;
  border-radius: 16px;
  overflow: hidden;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  background: #fff;
}

.listing-card:hover {
  transform: scale(1.02);
  box-shadow: 0 10px 25px rgba(0,0,0,0.12);
}
</style>

<div class="container mt-4">

  <h3 class="mb-3">Explore stays</h3>

  <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">

    <% allListings.forEach(listing => { %>

  <div class="col">

    <div class="card h-100 listing-card">

      <a href="/listings/<%= listing._id %>" style="text-decoration:none; color:inherit;">

        <img src="<%= listing.image.url %>" class="card-img-top listing-img">

        <div class="card-body listing-body">

          <div class="title"><%= listing.title %></div>

          <div class="location">
            <%= listing.location %>, <%= listing.country %>
          </div>

          <div class="d-flex justify-content-between align-items-center mt-2">

            <div class="price">
              <% if(listing.price) { %>
                ₹ <%= listing.price.toLocaleString("en-IN") %>
              <% } else { %>
                <span style="color:#999;">Price not set</span>
              <% } %>
            </div>

            <div class="badge-rating">
              ★ <%= listing.avgRating ? listing.avgRating.toFixed(1) : "New" %>
            </div>

          </div>

        </div>

      </a>

    </div>

  </div>

<% }) %>

  </div>

</div>